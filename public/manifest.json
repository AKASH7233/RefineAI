{
  "manifest_version": 3,
  "name": "RefineAI",
  "version": "1.0.0",
  "description": "Floating button to fix grammar and clarity with Gemini (streaming).",
  "host_permissions": ["https://generativelanguage.googleapis.com/*"],
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ]
}
